{
  "name": "koishi-plugin-analytics-fork",
  "description": "Show statistics for Koishi application (Fork with Day/Week/Month support)",
  "version": "0.1.2",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "dist",
    "src",
    "client",
    "build",
    "scripts",
    "tsconfig*.json",
    "yakumo.yml"
  ],
  "scripts": {
    "build": "yakumo build && npm run client",
    "client": "node scripts/build-client.mjs",
    "clean": "yakumo clean"
  },
  "author": "lumia.wang",
  "license": "AGPL-3.0",
  "keywords": [
    "bot",
    "chatbot",
    "koishi",
    "plugin",
    "chart",
    "console",
    "statistics",
    "analytics",
    "status"
  ],
  "yakumo": {
    "client": "./build/client.ts"
  },
  "koishi": {
    "public": [
      "dist"
    ],
    "description": {
      "en": "Show statistics for Koishi application",
      "zh": "在控制台中显示统计数据"
    },
    "service": {
      "required": [
        "console"
      ],
      "optional": [
        "database"
      ]
    }
  },
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.30.10",
    "koishi": "^4.18.9"
  },
  "devDependencies": {
    "@koishijs/assets": "^1.1.2",
    "@koishijs/client": "^5.30.10",
    "@types/node": "^22.10.0",
    "echarts": "^5.5.0",
    "koishi": "^4.18.9",
    "typescript": "^5.6.2",
    "vue": "^3.5.0",
    "vue-echarts": "^6.6.9",
    "yakumo": "^1.0.0-beta.21",
    "yakumo-esbuild": "^1.0.0-beta.8",
    "yakumo-tsc": "^1.0.0-beta.7"
  },
  "dependencies": {
    "@koishijs/console": "^5.30.10"
  }
}
